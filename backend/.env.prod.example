# ============================================================
# Bluechips London — Production Environment Variables
# Copy this to backend/.env.prod and fill in every value.
# NEVER commit .env.prod to git.
# ============================================================

# App
APP_NAME=Bluechips London
APP_ENV=production
FRONTEND_URL=https://bluechips.live
BACKEND_URL=https://api.bluechips.live
ALLOWED_ORIGINS=https://bluechips.live,https://www.bluechips.live

# Database  (must match POSTGRES_* in root .env)
POSTGRES_USER=bluechips
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=bluechips_london
DATABASE_URL=postgresql+asyncpg://bluechips:CHANGE_ME_STRONG_DB_PASSWORD@db:5432/bluechips_london

# Redis
REDIS_URL=redis://redis:6379/0

# Security — generate with: openssl rand -hex 64
SECRET_KEY=CHANGE_ME_64_CHAR_HEX_STRING
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Stripe — use LIVE keys (sk_live_... / pk_live_...)
STRIPE_SECRET_KEY=sk_live_CHANGE_ME
STRIPE_PUBLISHABLE_KEY=pk_live_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
STRIPE_ESSENTIAL_PRICE_ID=price_CHANGE_ME
STRIPE_PREMIUM_PRICE_ID=price_CHANGE_ME
STRIPE_ELITE_PRICE_ID=price_CHANGE_ME
STRIPE_ESSENTIAL_ANNUAL_PRICE_ID=price_CHANGE_ME
STRIPE_PREMIUM_ANNUAL_PRICE_ID=price_CHANGE_ME
STRIPE_ELITE_ANNUAL_PRICE_ID=price_CHANGE_ME
STRIPE_BLUE_TICK_SETUP_PRICE_ID=price_CHANGE_ME
STRIPE_BLUE_TICK_MONTHLY_PRICE_ID=price_CHANGE_ME

# Email (SMTP) — Resend SMTP relay
# Get your API key from resend.com → API Keys
EMAIL_FROM=noreply@bluechips.live
EMAIL_FROM_NAME=Bluechips London
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASSWORD=CHANGE_ME_RESEND_API_KEY

# Admin
ADMIN_EMAIL=mohdgazyanii235@gmail.com
ADMIN_INITIAL_PASSWORD=CHANGE_ME_STRONG_ADMIN_PASSWORD

# AWS S3 / Cloudflare R2 (optional — leave blank to use local Docker volume)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=auto
S3_BUCKET_NAME=bluechips-media
S3_ENDPOINT_URL=
S3_PUBLIC_URL=
